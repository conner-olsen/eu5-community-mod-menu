										button_drop = {
											enabled = "[CMMCanEditSetting(CMMListItemOwnerSettingKey(Scope.GetFlagName))]"
											onclick = "[GetVariableSystem.Set('cmm_dropdown_hover_index', ToString_int32(CMMListFieldDropdownSelectedIndex0(Scope.GetFlagName)))]"
											tooltip_enabled = no

											action_tooltip = {
												click_mode = single
												click_type = left
												click_modifier = shift
												title = "CMM_LIST_APPLY_OPTION_TO_ALL"
											}

											tooltipwidget = { BasicFunctionalTooltip = {} }
										}

										hbox = {
											using = layoutpolicy_expanding
											margin = { 5 0 }

											text_single = {
												using = layoutpolicy_expanding
												margin = { 10 0 }
												autoresize = no
												align = left|nobaseline
												fontsize_min = 13
												text = "[CMMListFieldDropdownLabel0(Scope.GetFlagName)]"
											}

											icon = {
												size = { 22 22 }
												texture = "gfx/interface/buttons/flats/button_simple_down.dds"
												using = color_gold
												modify_texture = {
													using = overlay_window_texture
													blend_mode = overlay
													alpha = 1
												}
											}
										}
									}
								}

								item = {
									widget = {
										size = { 100% 28 }

										button_dropdown = {
											enabled = "[CMMCanEditSetting(CMMListItemOwnerSettingKey(Scope.GetFlagName))]"
											onmousehierarchyenter = "[GetVariableSystem.Set('cmm_dropdown_hover_index', ToString_int32(PdxGuiWidget.GetIndexInDataModel))]"
											tooltip_enabled = no
										}

										text_single = {
											size = { 100% 100% }
											margin = { 15 0 }
											autoresize = no
											align = left|nobaseline
											fontsize_min = 13
											default_format = "#medium"
											text = "[CMMListFieldDropdownOptionLabel0(Scope.GetFlagName,PdxGuiWidget.GetIndexInDataModel)]"
										}
									}
								}

								list = {
									scrollarea = {
										size = { 100% 210 }
										position = { 0 28 }
										autoresizescrollarea = yes
										autoresizeviewport = yes
										alwaystransparent = yes
										scrollbarpolicy_horizontal = always_off

										background = {
											using = dropdown_list_background_template
										}

										maximumsize = { -1 210 }

										scrollwidget = {
											fixedgridbox = {
												setitemsizefromcell = yes
												alwaystransparent = no
												addcolumn = 100%
												addrow = 28
											}
										}

										scrollbar_vertical = {
											using = Scrollbar_Vertical
										}
									}
								}
							}

							button = {
								size = { 132 28 }
								parentanchor = center
								widgetanchor = center
								visible = "[And(CMMListFieldIsDropdown0(CMMListItemOwnerSettingKey(Scope.GetFlagName)), UIAction.IsLeftClickModifierEnabled('shift'))]"
								enabled = "[CMMCanEditSetting(CMMListItemOwnerSettingKey(Scope.GetFlagName))]"
								alpha = 0
								effectname = "NoHighlight"

								action_tooltip = {
									click_mode = single
									click_type = left
									click_modifier = shift
									title = "CMM_LIST_APPLY_OPTION_TO_ALL"
								}

								click_modifiers = {
									onshift = "[CMMMarkHoveredListPosition]"
									onshift = "[CMMMarkListFieldSlot0]"
									onshift = "[CMMMarkListFieldSelectDropdownAll]"
									onshift = "[GetScriptedGui(Concatenate('CMM_MarkDropdownSelection_', ToString_int32(CMMListFieldDropdownSelectedIndex0(Scope.GetFlagName)))).Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
									onshift = "[CMMExecuteSettingChanged(CMMListItemOwnerSettingKey(Scope.GetFlagName))]"
								}

								tooltipwidget = { BasicFunctionalTooltip = {} }
							}

						}

						widget = {
							size = { 132 28 }
							minimumsize = { 132 28 }
							visible = "[CMMListFieldHasSlot1(CMMListItemOwnerSettingKey(Scope.GetFlagName))]"

							checkbox_square_alt = {
								parentanchor = center
								widgetanchor = center
								visible = "[CMMListFieldIsBool1(CMMListItemOwnerSettingKey(Scope.GetFlagName))]"
								enabled = "[CMMCanEditSetting(CMMListItemOwnerSettingKey(Scope.GetFlagName))]"
								checked = "[CMMListFieldBoolChecked1(Scope.GetFlagName)]"
								tooltip_enabled = no
							}

							button = {
								size = { 24 24 }
								parentanchor = center
								widgetanchor = center
								visible = "[CMMListFieldIsBool1(CMMListItemOwnerSettingKey(Scope.GetFlagName))]"
								enabled = "[CMMCanEditSetting(CMMListItemOwnerSettingKey(Scope.GetFlagName))]"
								alpha = 0
								effectname = "NoHighlight"

								action_tooltip = {
									click_mode = single
									click_type = left
									click_modifier = shift
									title = "CMM_LIST_TOGGLE_ALL"
								}

								click_modifiers = {
									ondefault = "[CMMMarkListPosition(PdxGuiWidget.GetIndexInDataModel)]"
									ondefault = "[CMMMarkListFieldSlot1]"
									ondefault = "[CMMMarkListFieldToggle]"
									ondefault = "[CMMExecuteSettingChanged(CMMListItemOwnerSettingKey(Scope.GetFlagName))]"
									onshift = "[CMMMarkListPosition(PdxGuiWidget.GetIndexInDataModel)]"
									onshift = "[CMMMarkListFieldSlot1]"
									onshift = "[CMMMarkListFieldToggleAll]"
									onshift = "[CMMExecuteSettingChanged(CMMListItemOwnerSettingKey(Scope.GetFlagName))]"
								}

								tooltipwidget = {
									BasicFunctionalTooltip = {}
								}
							}

							hbox = {
								minimumsize = { 120 28 }
